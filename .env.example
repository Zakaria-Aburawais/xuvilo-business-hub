# ─────────────────────────────────────────────────────────────────────────────
# Xuvilo Business Hub — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# See HANDOVER.md and DATABASE.md for context on each variable.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/xuvilo

# Express session signing secret — use a long random string (32+ chars)
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string-here

# Public URL of this deployment (no trailing slash)
PUBLIC_APP_URL=https://xuvilo.com

# ── AI Providers ──────────────────────────────────────────────────────────────
# Used by api-server for RFQ Intelligence and AI Writer.
# Users can also supply their own keys in-app for RFQ — these are server defaults.

OPENAI_API_KEY=sk-...

# Anthropic and Gemini keys are entered by users in-app; not stored server-side.

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
# In Replit: injected automatically by the SendGrid integration.
# Outside Replit: create a free SendGrid account and generate an API key.

SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Xuvilo

# ── CAPTCHA (Cloudflare Turnstile) ────────────────────────────────────────────
# Get keys at https://dash.cloudflare.com → Turnstile → Create Widget
# For local dev only, use the always-pass test keys:
#   Site key:   1x00000000000000000000AA
#   Secret key: 1x0000000000000000000000000000000AA

TURNSTILE_SECRET_KEY=your_turnstile_secret_key
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# ── Analytics (optional) ──────────────────────────────────────────────────────

VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google AdSense (optional — approval in progress) ──────────────────────────
# Ad slot placement in the UI is not yet done. Set these when placing <AdSlot> components.

# VITE_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX
# VITE_ADSENSE_SLOT_ARTICLE=XXXXXXXXXX
# VITE_ADSENSE_SLOT_CALCULATOR=XXXXXXXXXX
# VITE_ADSENSE_SLOT_BLOG_INDEX=XXXXXXXXXX

# ── Payments / Stripe (currently disabled — enable when ready) ────────────────
# See HANDOVER.md → "Payments / Stripe" for the 3-step re-enable process.
# Do NOT set these until you are ready to re-enable billing.

# STRIPE_SECRET_KEY=sk_live_or_sk_test_xxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_xxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxx
# STRIPE_PRICE_PRO_MONTHLY=price_xxxxxx
# STRIPE_PRICE_PRO_YEARLY=price_xxxxxx
# STRIPE_PRICE_BUSINESS_MONTHLY=price_xxxxxx
# STRIPE_PRICE_BUSINESS_YEARLY=price_xxxxxx

# ── File / Object Storage ─────────────────────────────────────────────────────
# Used by api-server for RFQ PDF uploads.
# On Replit: these are injected automatically by the platform.
# On other platforms: replace the object storage client with S3/GCS/R2.

DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id
PRIVATE_OBJECT_DIR=private
PUBLIC_OBJECT_SEARCH_PATHS=public

# ── Contact form notifications (optional) ─────────────────────────────────────

CONTACT_TEAM_EMAIL=hello@yourdomain.com
CONTACT_FAILURE_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Spam alerting (optional) ──────────────────────────────────────────────────

SPAM_SPIKE_THRESHOLD=20
SPAM_SPIKE_WEBHOOK_URL=https://hooks.slack.com/services/...
SPAM_SPIKE_ALERT_EMAIL=admin@yourdomain.com
SPAM_SPIKE_DEBOUNCE_MINUTES=60

# ── Data retention (optional — these have sensible defaults) ──────────────────

SPAM_EVENTS_RETENTION_DAYS=30
RATE_LIMIT_BUCKETS_RETENTION_DAYS=7
PRUNE_HEALTH_DEBOUNCE_MINUTES=60

# ── Replit Platform (injected automatically — do not set manually) ─────────────
# Listed here for documentation only. Do not set in .env when running outside Replit.
#
# PORT                       — service port (each artifact gets a unique port)
# BASE_PATH                  — URL base path prefix (e.g. "/api")
# REPLIT_DOMAINS             — comma-separated list of public domains
# REPL_IDENTITY              — Replit identity token (connector proxy auth)
# WEB_REPL_RENEWAL           — connector proxy renewal token
# REPLIT_CONNECTORS_HOSTNAME — connector proxy hostname
